                "# Monte Carlo Forward Win Probability\n",
                "\n",
                "def mc_forward_win_probability(\n",
                "    sweep_row:      pd.Series,\n",
                "    price_data:     pd.DataFrame,\n",
                "    n_paths:        int   = 2000,\n",
                "    forward_bars:   int   = 65,      # ~10 trading days of hourly bars\n",
                "    min_move_pct:   float = 0.5,\n",
                "    seed:           int   = None,\n",
                ") -> float:\n",
                "    \"\"\"\n",
                "    Simulate n_paths forward price paths from the sweep close using\n",
                "    ATR-scaled GBM. Returns fraction of paths that achieve min_move_pct\n",
                "    in the correct direction — P(WIN) without waiting for outcomes.\n",
                "\n",
                "    Add 'p_win_mc' as a feature column in identify_sweeps_in_zones\n",
                "    or after label_sweep_outcomes.\n",
                "    \"\"\"\n",
                "    rng         = np.random.default_rng(seed)\n",
                "    sweep_ts    = pd.Timestamp(sweep_row.get('timestamp'))\n",
                "    sweep_close = float(sweep_row.get('reversal_price', np.nan))\n",
                "    sweep_type  = str(sweep_row.get('sweep_type', 'BULLISH'))\n",
                "    atr_val     = float(sweep_row.get('atr', np.nan))\n",
                "\n",
                "    if np.isnan(sweep_close) or sweep_close <= 0:\n",
                "        return np.nan\n",
                "\n",
                "    # Estimate drift + volatility from recent bars before the sweep\n",
                "    lookback_mask = (\n",
                "        (price_data.index < sweep_ts) &\n",
                "        (price_data.index >= sweep_ts - pd.Timedelta(hours=65))\n",
                "    )\n",
                "    hist = price_data.loc[lookback_mask, 'close']\n",
                "\n",
                "    if len(hist) < 10:\n",
                "        return np.nan\n",
                "\n",
                "    log_returns = np.log(hist / hist.shift(1)).dropna()\n",
                "    mu          = float(log_returns.mean())\n",
                "    sigma       = float(log_returns.std())\n",
                "\n",
                "    if sigma <= 0:\n",
                "        return np.nan\n",
                "\n",
                "    # GBM: S_t = S_0 * exp((mu - 0.5*sigma^2)*t + sigma*W_t)\n",
                "    dt         = 1.0   # 1 bar per step\n",
                "    rand_shocks = rng.standard_normal((n_paths, forward_bars))\n",
                "    log_steps   = (mu - 0.5 * sigma ** 2) * dt + sigma * np.sqrt(dt) * rand_shocks\n",
                "    log_paths   = np.cumsum(log_steps, axis=1)\n",
                "    price_paths = sweep_close * np.exp(log_paths)   # shape (n_paths, forward_bars)\n",
                "\n",
                "    # Check if any point on each path achieves min_move_pct\n",
                "    if sweep_type == 'BULLISH':\n",
                "        target        = sweep_close * (1.0 + min_move_pct / 100.0)\n",
                "        hit           = (price_paths >= target).any(axis=1)\n",
                "    else:\n",
                "        target        = sweep_close * (1.0 - min_move_pct / 100.0)\n",
                "        hit           = (price_paths <= target).any(axis=1)\n",
                "\n",
                "    return float(hit.mean())\n",
                "\n",
                "\n",
                "'''\n",
                "Add to sweep record in identify_sweeps_in_zones:\n",
                "\n",
                "# After building rec dict, before appending:\n",
                "rec['p_win_mc'] = mc_forward_win_probability(\n",
