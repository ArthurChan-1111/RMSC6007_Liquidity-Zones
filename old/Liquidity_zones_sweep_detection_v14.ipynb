                "# 2. Monte Carlo Parameter Sensitivity Analysis\n",
                "\n",
                "def mc_parameter_sensitivity(\n",
                "    sweeps_labeled: pd.DataFrame,\n",
                "    n_simulations:  int   = 1000,\n",
                "    seed:           int   = 42,\n",
                ") -> pd.DataFrame:\n",
                "    \"\"\"\n",
                "    Monte Carlo sensitivity analysis on the 5 key config thresholds.\n",
                "\n",
                "    For each simulation, perturb each parameter by ±U(0, perturbation_range)\n",
                "    and recompute win rate on the labeled sweep population.\n",
                "\n",
                "    Returns a DataFrame of (param, mean_winrate, std_winrate, sensitivity_rank).\n",
                "    Slots in after Part 7b calibration — call once after label_sweep_outcomes.\n",
                "    \"\"\"\n",
                "    rng = np.random.default_rng(seed)\n",
                "\n",
                "    # Parameters and their ±perturbation ranges (same units as config)\n",
                "    param_ranges = {\n",
                "        'MINZONECONVICTION':         (float(MINZONECONVICTION),        0.10),\n",
                "        'SWEEPMAXPENETRATIONPCT':    (float(SWEEPMAXPENETRATIONPCT),   1.00),\n",
                "        'invalidation_buffer':       (1.0,                             0.50),\n",
                "        'HTFFLIPCONFIRMDAYS':        (float(HTFFLIPCONFIRMDAYS),       8.00),\n",
                "        'HTFCONFLUENCEATRMULT':      (float(HTFCONFLUENCEATRMULT),     0.50),\n",
                "    }\n",
                "\n",
                "    df = sweeps_labeled[sweeps_labeled['outcome'] != 'TIMEOUT'].copy()\n",
                "    if df.empty:\n",
                "        return pd.DataFrame()\n",
                "\n",
                "    results = {p: [] for p in param_ranges}\n",
                "\n",
                "    for _ in range(n_simulations):\n",
                "        perturbed = {\n",
                "            p: base + rng.uniform(-rng_width, rng_width)\n",
                "            for p, (base, rng_width) in param_ranges.items()\n",
                "        }\n",
                "\n",
                "        # Re-filter sweep population with perturbed thresholds\n",
                "        mask = (\n",
                "            (df['sweep_quality_score'] >= 0)  # quality gate placeholder\n",
                "            & (df.get('htf_composite_score', pd.Series(1.0, index=df.index))\n",
                "               >= perturbed['MINZONECONVICTION'])\n",
                "            & (df.get('penetration_pct', pd.Series(0.0, index=df.index))\n",
                "               <= perturbed['SWEEPMAXPENETRATIONPCT'])\n",
                "        )\n",
                "        subset = df[mask]\n",
                "        if len(subset) < 10:\n",
                "            for p in param_ranges:\n",
                "                results[p].append(np.nan)\n",
                "            continue\n",
                "\n",
                "        win_rate = (subset['outcome'] == 'WIN').mean()\n",
                "        for p in param_ranges:\n",
                "            results[p].append(win_rate)\n",
                "\n",
                "    # Sensitivity = std of win rate across simulations (higher = more fragile)\n",
                "    rows = []\n",
                "    for p, wrs in results.items():\n",
                "        wrs_clean = [w for w in wrs if not np.isnan(w)]\n",
                "        if wrs_clean:\n",
                "            rows.append({\n",
                "                'parameter':        p,\n",
                "                'base_value':       param_ranges[p][0],\n",
                "                'perturbation':     param_ranges[p][1],\n",
                "                'mean_win_rate':    float(np.mean(wrs_clean)),\n",
                "                'std_win_rate':     float(np.std(wrs_clean)),\n",
                "                'sensitivity_rank': float(np.std(wrs_clean)),\n",
                "            })\n",
                "\n",
                "    result_df = pd.DataFrame(rows).sort_values('sensitivity_rank', ascending=False)\n",
                "    print(\"\\n── MC Parameter Sensitivity ──────────────────────────\")\n",
                "    print(result_df.to_string(index=False, float_format='{:.4f}'.format))\n",
                "    print(\"─\" * 54)\n",
                "    return result_df"
            ]
        },
