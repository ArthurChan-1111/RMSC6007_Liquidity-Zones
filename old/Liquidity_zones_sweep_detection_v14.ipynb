                "# 1. FULL COMPARISON TABLE\n",
                "# ══════════════════════════════════════════════════════════════════════════\n",
                "\n",
                "model_order = [\n",
                "    'B1: Majority class',\n",
                "    'B2: Quality score',\n",
                "    'B3: LR (sweep only)',\n",
                "    'B4: LR (sweep+regime)',\n",
                "    'B5: Teacher LR',\n",
                "    'B6: Teacher XGB',\n",
                "    'S1: Student (hard labels)',\n",
                "    'S2: Student (α=0.5)',\n",
                "    'S3: Student (α=0.7)',\n",
                "    'S4: Student (α=1.0)',\n",
                "]\n",
                "\n",
                "print(\"=\" * 105)\n",
                "print(f\"{'Model':<30} {'AUC':>12} {'Brier':>12} {'Accuracy':>12} {'Precision':>12} {'Recall':>12}\")\n",
                "print(\"=\" * 105)\n",
                "for name in model_order:\n",
                "    if name not in all_results:\n",
